CROQUIMAKER_TIMEOUT_SECONDS=240
CROQUIMAKER_MAX_UPLOAD_MB=80
CROQUIMAKER_CODEX_MODEL=gpt-5.6-sol
CROQUIMAKER_HOST_PORT=8081
CROQUIMAKER_PROVIDER=codex
# Opcional: senha inicial comum, com no minimo 12 caracteres.
# Se ficar vazia, o sistema gera senhas aleatorias individuais.
CROQUIMAKER_BOOTSTRAP_PASSWORD=
# Use 1 quando o acesso estiver publicado exclusivamente por HTTPS.
CROQUIMAKER_COOKIE_SECURE=0
