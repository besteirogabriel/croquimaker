FLASK_ENV=development
SECRET_KEY=
DATABASE_URL=sqlite:///data/croqui_engine.db
CROQUI_DATA_DIR=data
UPLOAD_DIR=data/uploads
OUTPUT_DIR=data/outputs
CROQUI_TMP_DIR=data/tmp
JOBEL_LOGO_PATH=croqui_engine/app/static/img/jobel_logo.png
CROQUI_ADMIN_EMAIL=
CROQUI_ADMIN_PASSWORD=
MAX_UPLOAD_MB=80
CROQUI_EXCEL_TEMPLATE_PATH=
CROQUI_GOLDEN_CORPUS_PATH=./CROQUI IA
CROQUI_ENGINE_MODE=v2
CROQUI_OPENAI_FALLBACK=true
CROQUI_OPENAI_FALLBACK_CONFIDENCE=0.72
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=high
OPENAI_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=2
OPENAI_PDF_DETAIL=high
OPENAI_MAX_PDF_MB=45
CROQUI_USE_OFFICIAL_CATALOG=true
CROQUI_ENABLE_BENCHMARK=true
CROQUI_USE_CORPUS_REFERENCE_OUTPUTS=false
